{
  "name": "@alekstar79/lightbox",
  "private": false,
  "version": "2.0.1",
  "type": "module",
  "description": "A modern, lightweight, and dependency-free lightbox library for images, with zoom, pan, and fullscreen features.",
  "author": "Aleksey Tarasenko <alekstar79@yandex.ru>",
  "license": "MIT",
  "keywords": [
    "lightbox",
    "gallery",
    "image",
    "zoom",
    "pan",
    "fullscreen",
    "typescript",
    "vite"
  ],
  "homepage": "https://github.com/alekstar79/lightbox#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alekstar79/lightbox.git"
  },
  "bugs": {
    "url": "https://github.com/alekstar79/lightbox/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./lib/styles.css": "./lib/styles.css"
  },
  "files": [
    "lib",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build:demo": "tsc && vite build",
    "build:lib": "tsc && vite build --config vite.lib.config.ts",
    "build": "npm run build:lib && npm run build:demo",
    "preview": "vite preview",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^2.0.0",
    "jsdom": "^24.0.0",
    "sass": "^1.77.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
